{
  "name": "ledebe-protector",
  "version": "1.0.0",
  "description": "Ledebe Protector - Let there be secure data protection",
  "author": "Ledebe",
  "main": "dist/main.js",
  "files": [
    "dist/",
    "*.html",
    "src/"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "dev:electron": "cross-env NODE_ENV=development concurrently -k \"npm:dev\" \"wait-on http://localhost:5173 && sleep 2 && electron .\"",
    "build": "tsc",
    "start": "electron-forge start",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:mac-universal": "npm run build && electron-builder --mac universal",
    "dist:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder --win nsis",
    "dist:win-portable": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder --win portable",
    "dist:all": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder --mac --win --linux",
    "dist:publish": "npm run build && electron-builder --publish always",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:core": "npm run build && playwright test \"QA testing/playwright/\"",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:cypress": "npm run dev & wait-on http://localhost:5173 && cypress run",
    "test:cypress:open": "npm run dev & wait-on http://localhost:5173 && cypress open",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "security:audit": "npm audit",
    "test:all": "npm run lint && npm run format:check && npm run build && npm run test:core",
    "deploy:website": "./deployments/deploy.sh",
    "test:install": "playwright install chromium"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.57.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@wdio/cli": "^9.21.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "cypress": "^13.6.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-playwright-helpers": "^2.0.1",
    "eslint": "^9.39.2",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.5",
    "wait-on": "^9.0.3",
    "wdio-electron-service": "^9.2.1",
    "@electron/notarize": "^2.5.0",
    "cypress-plugin-tab": "^1.0.0"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "build": {
    "appId": "com.ledebe.protector",
    "productName": "Ledebe Protector",
    "copyright": "Copyright © 2025 Ledebe. All rights reserved.",
    "files": [
      "dist/**/*",
      "*.html",
      "ai-chat.js",
      "multi-ai-chat.js",
      "company-sync.js",
      "!src/**/*",
      "!node_modules/**/*",
      "!**/*.ts",
      "!tsconfig.json",
      "!vite.config.mts"
    ],
    "directories": {
      "output": "dist-build"
    },
    "compression": "maximum",
    "mac": {
      "category": "public.app-category.productivity",
      "notarize": false,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Install Ledebe Protector",
      "backgroundColor": "#1e3a8a",
      "window": {
        "width": 600,
        "height": 400
      },
      "contents": [
        {
          "x": 150,
          "y": 200,
          "type": "file"
        },
        {
          "x": 450,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "forceCodeSigning": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Ledebe Protector",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "generic",
      "url": "http://ledebe.s3-website.us-east-2.amazonaws.com/downloads/"
    },
    "afterSign": "scripts/notarize.js",
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}