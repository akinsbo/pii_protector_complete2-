{
  "manifest_version": 3,
  "name": "Ledebe Browser Protector",
  "version": "0.1.0",
  "description": "Detect and protect sensitive data before it is sent from browser text fields.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Ledebe Browser Protector",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "ledebe-icon.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "js": [
        "detector.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
