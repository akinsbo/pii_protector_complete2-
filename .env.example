# GitHub configuration for crash reporting and feedback storage
GITHUB_TOKEN=your_github_token_here
CRASH_GIST_ID=your_gist_id_here

# Slack webhook for crash notifications (optional)
CRASH_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Default AI model configuration
DEFAULT_AI_MODEL=gpt-3.5-turbo

# OpenAI API Key (optional - users can set this in settings)
OPENAI_API_KEY=

# Anthropic API Key (optional - users can set this in settings)
ANTHROPIC_API_KEY=

# Google API Key (optional - users can set this in settings)
GOOGLE_API_KEY=
