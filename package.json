{
  "name": "ledebe-protector",
  "version": "1.0.0",
  "description": "Ledebe - Let there be secure data protection",
  "author": "Ledebe",
  "main": "dist/main.js",
  "files": [
    "dist/",
    "*.html",
    "src/"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "dev:electron": "cross-env NODE_ENV=development concurrently -k \"npm:dev\" \"wait-on https://localhost:5173 && sleep 2 && electron .\"",
    "build": "tsc",
    "start": "electron-forge start",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:mac-universal": "npm run build && electron-builder --mac universal",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "security:audit": "npm audit",
    "test:all": "npm run lint && npm run format:check && npm run build && npm run test:e2e",
    "deploy:website": "./deployments/deploy.sh"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.57.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@wdio/cli": "^9.21.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "electron-playwright-helpers": "^1.8.2",
    "eslint": "^9.39.1",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "typescript": "^5.6.0",
    "vite": "^5.4.10",
    "wait-on": "^7.0.1",
    "wdio-electron-service": "^9.2.1"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "build": {
    "appId": "com.ledebe.protector",
    "productName": "Ledebe Protector",
    "icon": "icon.png",
    "files": [
      "dist/**/*",
      "*.html",
      "icon.svg",
      "!src/**/*",
      "!node_modules/**/*",
      "!**/*.ts",
      "!tsconfig.json",
      "!vite.config.mts"
    ],
    "directories": {
      "output": "dist-build"
    },
    "compression": "maximum",
    "mac": {
      "category": "public.app-category.productivity"
    }
  }
}
